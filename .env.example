# Proof of Real — environment configuration
# Copy to .env.local for development.  NEVER commit real secrets.

# Data backend: "local" (JSON file, default for dev), "supabase", or "dynamodb".
# If unset: supabase when SUPABASE_URL is set, else dynamodb when
# DYNAMODB_TABLE is set, else local.
DATA_BACKEND=local

# --- Registry signing keys (Ed25519, base64-encoded PEM) ---
# Generate with: node scripts/gen-registry-key.mjs
# Records are sealed with the private key and verified with the public key.
REGISTRY_PRIVATE_KEY=
REGISTRY_PUBLIC_KEY=

# --- Flare (Coston2 testnet) anchoring ---
# Generate a deployer wallet with: node scripts/gen-flare-wallet.mjs
# Fund it (free test C2FLR): https://faucet.flare.network/coston2
# Deploy the anchor contract with: node scripts/deploy-anchor.mjs
FLARE_DEPLOYER_PRIVATE_KEY=
FLARE_DEPLOYER_ADDRESS=
FLARE_RPC_URL=https://coston2-api.flare.network/ext/C/rpc
# Set automatically by deploy-anchor.mjs; the deployed ProofOfRealAnchor contract.
FLARE_ANCHOR_ADDRESS=

# --- Confidential verifier enclave (Google Cloud Confidential Space) ---
# When set, verify uploads go from the browser DIRECTLY to the enclave;
# the registry server never sees the image. Leave empty to verify server-side.
# Local dev:  node enclave/server.mjs  →  http://localhost:8080
NEXT_PUBLIC_ENCLAVE_URL=

# --- Supabase (production, zero-AWS) ---
# Create a project at https://supabase.com, run supabase/schema.sql in the
# SQL editor, then copy these from Project Settings → API. The service-role
# key is SERVER-ONLY — never expose it with a NEXT_PUBLIC_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AWS DynamoDB (alternative production backend) ---
DYNAMODB_TABLE=proof-of-real
AWS_REGION=us-east-1
# Credentials: provide via the standard AWS chain (env vars, profile, or the
# Vercel/Amplify integration). For local testing against real AWS you can set:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
