# Proof of Real — environment configuration
# Copy to .env.local for development.  NEVER commit real secrets.

# Data backend: "local" (JSON file, default for dev) or "dynamodb".
# If DYNAMODB_TABLE is set, dynamodb is used automatically.
DATA_BACKEND=local

# --- AWS DynamoDB (production) ---
DYNAMODB_TABLE=proof-of-real
AWS_REGION=us-east-1
# Credentials: provide via the standard AWS chain (env vars, profile, or the
# Vercel/Amplify integration). For local testing against real AWS you can set:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
